# SERVER
PORT=3000
NODE_ENV=development

# DATABASE (PostgreSQL via Docker)
DATABASE_URL="postgresql://postgres:password@localhost:5432/boilerplate"

# JWT AUTHENTIFICATION
JWT_SECRET=change_this_secret_key_minimum_32_characters
JWT_REFRESH_SECRET=change_this_refresh_secret_minimum_32_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# FEDAPAY (Mobile Money)
# Obtenez vos clés sur https://dashboard.fedapay.com
FEDAPAY_API_KEY=pk_sandbox_xxx
FEDAPAY_WEBHOOK_SECRET=whsec_xxx
FEDAPAY_SUCCESS_URL=http://localhost:3000/api/v1/paiement/success
FEDAPAY_CANCEL_URL=http://localhost:3000/api/v1/paiement/cancel

# OPTIONNEL - Email (pour version future)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password